# ──────────────────────────────────────────────────────────────
# Pace Controller Configuration
# ──────────────────────────────────────────────────────────────
#
# This file controls the pace controller's behavior. To apply
# changes without restarting the container:
#
#   1. Edit this file
#   2. curl -X POST http://localhost:3100/reload
#
# The new values take effect on the next sleep/wake cycle.
#
# Useful endpoints:
#   GET  /status  — current state, head block, config
#   GET  /health  — health check (200 or 503)
#   POST /wake    — wake the chain immediately
#   POST /reload  — re-read this file and apply new values
# ──────────────────────────────────────────────────────────────

# Comma-separated producer API URLs (not reloadable — requires restart)
PRODUCER_URLS=http://producer1:8888,http://producer2:8888,http://producer3:8888,http://producer4:8888

# Consecutive empty blocks before sleeping (at 5s/block, 20 = ~100s idle)
IDLE_BLOCK_THRESHOLD=20

# How long to sleep when idle (ms) — default 3600000 = 1 hour
SLEEP_DURATION_MS=3600000

# How long to stay awake during a wake check (ms) — default 120000 = 2 minutes
# All 4 producers remain active for the full duration
WAKE_DURATION_MS=120000

# Health check interval (ms) — re-pauses producers that restart during sleep
HEALTH_CHECK_INTERVAL_MS=30000
