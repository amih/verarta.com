# BLS Finalizer Keys for Savanna Consensus
# Generated with: spring-util bls create key --to-console
#
# Run inside each producer container:
#   docker exec -it verarta-producer1 spring-util bls create key --to-console
#   docker exec -it verarta-producer2 spring-util bls create key --to-console
#   docker exec -it verarta-producer3 spring-util bls create key --to-console
#   docker exec -it verarta-producer4 spring-util bls create key --to-console
#
# Copy this file to blockchain/.env and fill in the generated keys.

# Producer 1
PRODUCER1_BLS_PRIVATE=PVT_BLS_...
PRODUCER1_BLS_PUBLIC=PUB_BLS_...

# Producer 2
PRODUCER2_BLS_PRIVATE=PVT_BLS_...
PRODUCER2_BLS_PUBLIC=PUB_BLS_...

# Producer 3
PRODUCER3_BLS_PRIVATE=PVT_BLS_...
PRODUCER3_BLS_PUBLIC=PUB_BLS_...

# Producer 4
PRODUCER4_BLS_PRIVATE=PVT_BLS_...
PRODUCER4_BLS_PUBLIC=PUB_BLS_...
